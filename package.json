{
	"name": "espe-actionsheet",
	"version": "2026.1.3",
	"description": "ESPE ActionSheet for React-Native",
	"source": "index.tsx",
	"main": "index.tsx",
	"scripts": {
		"typecheck": "tsc --noEmit",
		"bump": "standard-version --no-git-tag-version && git push origin && git push origin v$(node -p \"require('./package.json').version\") && echo \"Package $(node -p \"require('./package.json').name\") has been updated to version $(node -p \"require('./package.json').version\")\""
	},
	"keywords": [
		"react-native",
		"actionsheet",
		"ios",
		"android"
	],
	"repository": {
		"type": "git",
		"url": "git+https://github.com/espe-org/espe-actionsheet.git"
	},
	"author": "Salavat Iskhakov <salavat@projecto.pro> (https://github.com/espe-org)",
	"license": "MIT",
	"bugs": {
		"url": "https://github.com/espe-org/espe-actionsheet/issues"
	},
	"homepage": "https://github.com/espe-org/espe-actionsheet#readme",
	"publishConfig": {
		"registry": "https://registry.npmjs.org/"
	},
	"devDependencies": {
		"@types/react": "19.0.10",
		"react": "19.1.0",
		"react-native": "0.82.1",
		"standard-version": "9.5.0",
		"typescript": "5.9.3"
	},
	"peerDependencies": {
		"react": "*",
		"react-native": "*"
	},
	"packageManager": "yarn@3.6.4",
	"dependencies": {
		"@react-native-menu/menu": "2.0.0",
		"moment": "2.30.1",
		"react-native-device-info": "15.0.1",
		"react-native-modal": "14.0.0-rc.1"
	}
}
